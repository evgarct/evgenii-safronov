{
  "shape": {
    "control": { "$type": "dimension", "$value": "{radius.md}", "$description": "Default interactive control radius" },
    "container": { "$type": "dimension", "$value": "{radius.lg}", "$description": "Default content container radius" },
    "elevated": { "$type": "dimension", "$value": "{radius.xl}", "$description": "Elevated content radius" },
    "pill": { "$type": "dimension", "$value": "{radius.full}", "$description": "Pill and badge radius" }
  },
  "layout": {
