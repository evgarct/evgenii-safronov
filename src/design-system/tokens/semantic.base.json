      "wide": { "$type": "dimension", "$value": "{container.wide}", "$description": "Wide layout container" }
    },
    "breakpoint": {
      "sm": { "$type": "dimension", "$value": "{breakpoint.sm}", "$description": "Small responsive boundary" },
